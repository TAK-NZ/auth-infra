{
  "testEnvironment": "node",
  "roots": ["<rootDir>/test"],
  "testMatch": ["**/*.test.ts"],
  "testPathIgnorePatterns": [
    "/node_modules/",
    "/test/__fixtures__/",
    "/test/__helpers__/"
  ],
  "transform": {
    "^.+\\.ts$": ["@swc/jest"]
  },
  "coverageReporters": ["text"],
  "collectCoverageFrom": [
    "lib/**/*.ts",
    "!lib/**/*.d.ts"
  ],
  "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json", "node"]
}
